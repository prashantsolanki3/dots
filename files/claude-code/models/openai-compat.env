# ── Provider: OpenAI-compatible / LLM gateway endpoint ───────────────────────
#
# Tested: ANTHROPIC_BASE_URL confirmed as the correct var for gateway routing
#         (official docs: "llm-gateway" section). Template-only otherwise —
#         model strings and auth depend entirely on your gateway.
# Gotcha: when ANTHROPIC_BASE_URL points to a non-Anthropic host, MCP tool
#         search is disabled by default to avoid compatibility issues.
#
# Use this profile to route Claude Code through any OpenAI-compatible gateway:
# LiteLLM, Azure OpenAI, a local Ollama instance, etc.
# The gateway must implement the Anthropic Messages API surface.
#
# Authentication (set in your machine shell profile, NOT here)
#   export ANTHROPIC_API_KEY=your-gateway-key   # or "none" for local gateways
#
# Prerequisites
#   - ANTHROPIC_BASE_URL must be set per machine (see below).
#   - Your gateway must accept Anthropic Messages API format requests.
#
# Docs: https://docs.anthropic.com/en/docs/claude-code/settings (proxy section)
# ─────────────────────────────────────────────────────────────────────────────

# No CLAUDE_CODE_USE_* flag — provider is selected by ANTHROPIC_BASE_URL alone.
unset CLAUDE_CODE_USE_BEDROCK
unset CLAUDE_CODE_USE_VERTEX
unset CLAUDE_CODE_USE_FOUNDRY

# Gateway URL — must be set per machine. Examples:
#   export ANTHROPIC_BASE_URL=http://localhost:11434/v1   # local Ollama
#   export ANTHROPIC_BASE_URL=https://litellm.your-org.com

# Model name sent to your gateway. Set to whatever model ID the gateway exposes.
# If unset, the alias from settings.json is forwarded and the gateway must
# understand it (most gateways do not — set this explicitly).
# export ANTHROPIC_DEFAULT_OPUS_MODEL=gpt-4o        # Azure OpenAI example
# export ANTHROPIC_DEFAULT_OPUS_MODEL=llama3         # Ollama example
