# ── Provider: Anthropic API (direct) ─────────────────────────────────────────
#
# Tested: env var names and model IDs confirmed against official docs.
#
# Authentication
#   Set ANTHROPIC_API_KEY in your system keychain or machine shell profile.
#   Never put the key value in this file — this file is checked into git.
#
# Optional: route through a proxy or API gateway
#   export ANTHROPIC_BASE_URL=https://your-proxy.example.com
#
# Docs: https://docs.anthropic.com/en/docs/claude-code/settings
# ─────────────────────────────────────────────────────────────────────────────

# No provider flag needed — Anthropic is the default when none of the
# CLAUDE_CODE_USE_* vars are set.
unset CLAUDE_CODE_USE_BEDROCK
unset CLAUDE_CODE_USE_VERTEX
unset CLAUDE_CODE_USE_FOUNDRY

# Pin exact model versions for each Claude Code alias.
# These resolve the opusplan/opus/sonnet/haiku aliases in settings.json.
# Update when new model versions are released.
export ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
export ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
export ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5-20251001
