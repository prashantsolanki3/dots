# ── Provider: Microsoft Azure AI Foundry ─────────────────────────────────────
#
# Tested: CLAUDE_CODE_USE_FOUNDRY and ANTHROPIC_FOUNDRY_RESOURCE var names
#         confirmed from Claude Code source/docs. Model pinning is template-only
#         — deployment names depend on what you create in Foundry.
# Gotcha: Foundry support may still be in preview; verify availability in your
#         Azure region before relying on this profile.
#
# Authentication (set in your machine shell profile, NOT here)
#   Option A — Azure CLI:
#     az login
#   Option B — service principal:
#     export AZURE_CLIENT_ID=...
#     export AZURE_CLIENT_SECRET=...
#     export AZURE_TENANT_ID=...
#
# Prerequisites
#   - Deploy a Claude model in Azure AI Foundry.
#   - Set ANTHROPIC_FOUNDRY_RESOURCE to your Foundry resource name (per machine).
#
# Docs: check current Claude Code release notes — Foundry support is evolving.
# ─────────────────────────────────────────────────────────────────────────────

export CLAUDE_CODE_USE_FOUNDRY=1
unset CLAUDE_CODE_USE_BEDROCK
unset CLAUDE_CODE_USE_VERTEX

# Foundry resource name — required, set per machine.
# export ANTHROPIC_FOUNDRY_RESOURCE=your-foundry-resource-name

# Model pinning — set to your Foundry deployment name, not a Claude model ID.
# export ANTHROPIC_DEFAULT_OPUS_MODEL=your-foundry-claude-opus-deployment
