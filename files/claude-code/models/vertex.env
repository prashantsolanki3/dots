# ── Provider: Google Vertex AI ────────────────────────────────────────────────
#
# Tested: env var names and model string format confirmed against official
#         Claude Code Vertex AI docs. Short-name format (claude-opus-4-6)
#         and versioned format (claude-haiku-4-5@20251001) both confirmed valid.
#
# Authentication (set in your machine shell profile, NOT here)
#   Option A — application default credentials (recommended):
#     gcloud auth application-default login
#   Option B — service account key file:
#     export GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json
#
# Prerequisites
#   - Enable the Vertex AI API in your GCP project.
#   - Ensure Claude models are available in CLOUD_ML_REGION.
#   - Set ANTHROPIC_VERTEX_PROJECT_ID to your GCP project ID (per machine).
#
# Docs: https://docs.anthropic.com/en/docs/claude-code/google-vertex-ai
# ─────────────────────────────────────────────────────────────────────────────

export CLAUDE_CODE_USE_VERTEX=1
unset CLAUDE_CODE_USE_BEDROCK
unset CLAUDE_CODE_USE_FOUNDRY

# GCP project — required, set per machine.
# export ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id

# Region — "us-east5" is commonly available; "global" routes to nearest.
export CLOUD_ML_REGION=${CLOUD_ML_REGION:-us-east5}

# Model strings for Vertex AI.
# Short form is simpler; versioned form (@date) pins to a specific release.
# Use versioned form if you need to prevent silent upgrades.
export ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-6
export ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
export ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5@20251001
