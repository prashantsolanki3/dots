# ── Provider: AWS Bedrock ─────────────────────────────────────────────────────
#
# Tested: env var names confirmed against official Claude Code Bedrock docs.
#         Model string format confirmed (cross-region inference profile IDs).
#         Gotcha: model string format differs per model — see comments below.
#
# Authentication (set in your machine shell profile, NOT here)
#   Option A — static keys:
#     export AWS_ACCESS_KEY_ID=...
#     export AWS_SECRET_ACCESS_KEY=...
#   Option B — IAM role / SSO (recommended for EC2/ECS):
#     export AWS_BEARER_TOKEN_BEDROCK=...   (short-lived token)
#   Option C — AWS named profile:
#     export AWS_PROFILE=my-bedrock-profile
#
# Prerequisites
#   - Enable cross-region inference profile access in the AWS console.
#   - AWS_REGION must be in the same geo group as your model prefix (us/eu/ap).
#   - Replace the 'us.' geo prefix below if your region is eu-* or ap-*.
#
# Docs: https://docs.anthropic.com/en/docs/claude-code/bedrock
# ─────────────────────────────────────────────────────────────────────────────

export CLAUDE_CODE_USE_BEDROCK=1
unset CLAUDE_CODE_USE_VERTEX
unset CLAUDE_CODE_USE_FOUNDRY

# Region — override per machine if needed.
export AWS_REGION=${AWS_REGION:-us-east-1}

# Cross-region inference profile IDs (recommended format for Bedrock).
# Gotcha: the suffix format is inconsistent across models (confirmed from docs):
#   Opus   → -v1           (versioned, no date in ID)
#   Sonnet → -v1           (versioned, no date in ID — same as Opus)
#   Haiku  → -v1:0         (versioned with :0 qualifier)
export ANTHROPIC_DEFAULT_OPUS_MODEL=us.anthropic.claude-opus-4-6-v1
export ANTHROPIC_DEFAULT_SONNET_MODEL=us.anthropic.claude-sonnet-4-6-v1
export ANTHROPIC_DEFAULT_HAIKU_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0
